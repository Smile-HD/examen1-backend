APP_ENV=production
APP_NAME=Emergencias API
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=10000

# Base de datos (Render Postgres)
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DBNAME

# Seguridad
AUTH_SECRET_KEY=CAMBIA_ESTA_CLAVE_SUPER_SECRETA

# Notificaciones push FCM (recomendado: HTTP v1 con cuenta de servicio)
# Opcion A (recomendada para Render): JSON completo de cuenta de servicio en una sola variable.
FCM_SERVICE_ACCOUNT_JSON=
# Opcion B (alternativa local): ruta al archivo JSON descargado desde Firebase > Cuentas de servicio.
# GOOGLE_APPLICATION_CREDENTIALS=/ruta/absoluta/service-account.json
# Opcional: project id explicito si no viene en credenciales.
FCM_PROJECT_ID=

# Fallback legacy (no disponible en proyectos nuevos; mantener vacio salvo legado)
FCM_SERVER_KEY=

# IA de audio (Vosk)
AI_ENABLE_AUDIO_TRANSCRIPTION=true
AI_TRANSCRIPTION_PROVIDER=vosk
AI_VOSK_MODEL_PATH=/app/models/vosk-model-small-es-0.42
AI_VOSK_SAMPLE_RATE=16000
AI_VOSK_FFMPEG_PATH=ffmpeg

# IA de imagen (opcional)
AI_ENABLE_HF_IMAGE=false
AI_HF_IMAGE_MODEL=microsoft/resnet-50
AI_HF_IMAGE_MODEL_FALLBACK=google/vit-base-patch16-224
AI_HF_MAX_RETRIES=2
AI_HF_RETRY_BACKOFF_SECONDS=2
AI_HF_TOKEN=

# Evidencias locales (opcional)
# EVIDENCE_STORAGE_DIR=/var/data/uploads/evidencias
